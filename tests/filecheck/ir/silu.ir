// RUN: ffcc-opt -p approx{exp},cse,simp %s | filecheck %s
// RUN: ffcc-opt -p approx{exp},cse,simp %s -f llvm | opt -S | filecheck %s --check-prefix=LLVM
// RUN: ffcc-opt -p approx{exp},cse,simp %s -f llvm --vectorize 8 | opt -S | filecheck %s --check-prefix=LLVM_VEC

%x = var x : f32
%one = constant 1 : f32
%e = constant e : f32
%mx = negate %x : f32
%exp = pow %e, %mx : f32
%one_p_ex = add %one, %exp : f32
%d = div %one, %one_p_ex : f32
%res = mul %x, %d : f32

// CHECK:      %x = var 'x' : f32
// CHECK-NEXT: %one = constant 1 : f32
// CHECK-NEXT: %LB = tunable 'LB' = 1064975337.7308671 : f32
// CHECK-NEXT: %L = tunable 'L' = -12102203.161561485 : f32
// CHECK-NEXT: %0 = mul %L, %x : f32
// CHECK-NEXT: %1 = add %LB, %0 : f32
// CHECK-NEXT: %2 = bitcast i2f %1 to f32
// CHECK-NEXT: %one_p_ex = add %one, %2 : f32
// CHECK-NEXT: %3 = div %x, %one_p_ex : f32

// LLVM:      define float @my_func(float %x, float %L, float %LB) {
// LLVM-NEXT:   %1 = fmul float %L, %x
// LLVM-NEXT:   %2 = fadd float %LB, %1
// LLVM-NEXT:   %cast = fptosi float %2 to i32
// LLVM-NEXT:   %3 = bitcast i32 %cast to float
// LLVM-NEXT:   %one_p_ex = fadd float 1.000000e+00, %3
// LLVM-NEXT:   %4 = fdiv float %x, %one_p_ex
// LLVM-NEXT:   ret float %4
// LLVM-NEXT: }

// LLVM_VEC:      define <8 x float> @my_func(<8 x float> %x, float %L, float %LB) {
// LLVM-VEC-NEXT:   %L_1 = insertelement <8 x float> poison, float %L, i64 0
// LLVM-VEC-NEXT:   %L_2 = shufflevector <8 x float> %L_1, <8 x float> poison, <8 x i32> zeroinitializer
// LLVM-VEC-NEXT:   %LB_1 = insertelement <8 x float> poison, float %LB, i64 0
// LLVM-VEC-NEXT:   %LB_2 = shufflevector <8 x float> %LB_1, <8 x float> poison, <8 x i32> zeroinitializer
// LLVM-VEC-NEXT:   %1 = fmul <8 x float> %L_2, %x
// LLVM-VEC-NEXT:   %2 = fadd <8 x float> %LB_2, %1
// LLVM-VEC-NEXT:   %cast = fptosi <8 x float> %2 to <8 x i32>
// LLVM-VEC-NEXT:   %3 = bitcast <8 x i32> %cast to <8 x float>
// LLVM-VEC-NEXT:   %one_p_ex = fadd <8 x float> splat (float 1.000000e+00), %3
// LLVM-VEC-NEXT:   %4 = fdiv <8 x float> %x, %one_p_ex
// LLVM-VEC-NEXT:   ret <8 x float> %4
// LLVM-VEC-NEXT: }
