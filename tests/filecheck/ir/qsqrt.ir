// RUN: ffcc-opt %s -p simp,approx{exp,div},cse,simp,types | filecheck %s
// RUN: ffcc-opt %s -p simp,approx{exp,div},cse,simp,types -f llvm | opt -S | filecheck --check-prefix=LLVM %s

%x = var x : f32
%half = constant 0.5 : f32
%one = constant 1 : f32

%pow = pow %x, %half : f32
%div = div %one, %pow : f32


// CHECK:      %LB = tunable 'LB' = 1064975338 : i32
// CHECK-NEXT: %L = tunable 'L' = -4194304.0 : f32
// CHECK-NEXT: %x = var 'x' : f32
// CHECK-NEXT: %0 = constant 2 : f32
// CHECK-NEXT: %1 = log %x, base=%0 : f32
// CHECK-NEXT: %2 = mul %L, %1 : f32
// CHECK-NEXT: %3 = add %LB, %2 : i32
// CHECK-NEXT: %4 = bitcast i2f %3 to f32


// LLVM:      define float @my_func(float %x, float %L, i32 %LB) {
// LLVM-NEXT:   %1 = call float @llvm.log2.f32(float %x)
// LLVM-NEXT:   %2 = fmul float %L, %1
// LLVM-NEXT:   %cast = fptosi float %2 to i32
// LLVM-NEXT:   %3 = add i32 %LB, %cast
// LLVM-NEXT:   %4 = bitcast i32 %3 to float
// LLVM-NEXT:   ret float %4
// LLVM-NEXT: }

