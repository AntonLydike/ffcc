// RUN: ffcc-opt -p approx{exp},simp,cse %s | filecheck %s --match-full-lines
// RUN: ffcc-opt -p approx{exp},simp,cse %s -f llvm | opt -S | filecheck %s --check-prefix=LLVM --match-full-lines

// e2x = (e^2x)
// res = (e2x - 1) / (e2x + 1)
%x = var x : f32
%2 = constant 2 : f32
%1 = constant 1 : f32
%e = constant e : f32
%2x = mul %2, %x : f32
%e2x = pow %e, %2x : f32
%top = sub %e2x, %1 : f32
%bot = add %e2x, %1 : f32
%res = div %top, %bot : f32

// CHECK-NEXT: %LB = tunable 'LB' = 1064988311.552 : f32
// CHECK-NEXT: %L = tunable 'L' = 24204406.32312297 : f32
// CHECK-NEXT: %x = var 'x' : f32
// CHECK-NEXT: %0 = mul %L, %x : f32
// CHECK-NEXT: %1 = add %LB, %0 : f32
// CHECK-NEXT: %2 = bitcast i2f %1 to f32
// CHECK-NEXT: %3 = constant 1 : f32
// CHECK-NEXT: %top = sub %2, %3 : f32
// CHECK-NEXT: %4 = add %3, %2 : f32
// CHECK-NEXT: %res = div %top, %4 : f32

// LLVM-NEXT: ; ModuleID = '<stdin>'
// LLVM-NEXT: source_filename = "<stdin>"
// LLVM-EMPTY:
// LLVM-NEXT: define float @my_func(float %x, float %L, float %LB) {
// LLVM-NEXT:   %1 = fmul float %L, %x
// LLVM-NEXT:   %2 = fadd float %LB, %1
// LLVM-NEXT:   %cast = fptosi float %2 to i32
// LLVM-NEXT:   %3 = bitcast i32 %cast to float
// LLVM-NEXT:   %top = fsub float %3, 1.000000e+00
// LLVM-NEXT:   %4 = fadd float 1.000000e+00, %3
// LLVM-NEXT:   %res = fdiv float %top, %4
// LLVM-NEXT:   ret float %res
// LLVM-NEXT: }
