// RUN: ffcc-opt -p simp,approx{exp,log},simp,cse %s | filecheck %s
// RUN: ffcc-opt -p simp,approx{exp,log},simp,cse %s -f llvm | opt -S | filecheck %s --check-prefix=LLVM

%x = var x : f32
%e = constant e : f32
%one = constant 1 : f32
%ex = pow %e, %x : f32
%1px = add %one, %ex : f32
%res = ln %1px : f32

// CHECK:      %B = tunable 'B' = -87.9995400287587 : f32
// CHECK-NEXT: %L = tunable 'L' = 8.262958294867817e-08 : f32
// CHECK-NEXT: %one = constant 1 : f32
// CHECK-NEXT: %LB = tunable 'LB' = 1064988311.552 : f32
// CHECK-NEXT: %L1 = tunable 'L' = 12102203.161561485 : f32
// CHECK-NEXT: %x = var 'x' : f32
// CHECK-NEXT: %0 = mul %L1, %x : f32
// CHECK-NEXT: %1 = add %LB, %0 : f32
// CHECK-NEXT: %2 = bitcast i2f %1 to f32
// CHECK-NEXT: %3 = add %one, %2 : f32
// CHECK-NEXT: %4 = bitcast f2i %3 to i32
// CHECK-NEXT: %5 = mul %L, %4 : f32
// CHECK-NEXT: %6 = add %B, %5 : f32

// LLVM:      define float @my_func(float %x, float %B, float %L, float %L_1, float %LB) {
// LLVM-NEXT:   %1 = fmul float %L_1, %x
// LLVM-NEXT:   %2 = fadd float %LB, %1
// LLVM-NEXT:   %cast = fptosi float %2 to i32
// LLVM-NEXT:   %3 = bitcast i32 %cast to float
// LLVM-NEXT:   %4 = fadd float 1.000000e+00, %3
// LLVM-NEXT:   %5 = bitcast float %4 to i32
// LLVM-NEXT:   %cast_1 = sitofp i32 %5 to float
// LLVM-NEXT:   %6 = fmul float %L, %cast_1
// LLVM-NEXT:   %7 = fadd float %B, %6
// LLVM-NEXT:   ret float %7
// LLVM-NEXT: }
