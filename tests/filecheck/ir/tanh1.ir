// RUN: ffcc -p approx,cse,simp,types %s | filecheck %s --match-full-lines
// RUN: ffcc -p approx,cse,simp,types %s -f llvm | opt -S | filecheck %s --check-prefix=LLVM --match-full-lines

// ex = e^-x
// emx = 1/emx
// res = (ex - emx) / (ex + emx)
%x = var x : f32
%one = constant 1 : f32
%e = constant e : f32
%ex = pow %e, %x : f32
%emx = div %one, %ex : f32
%top = sub %ex, %emx : f32
%btm = add %ex, %emx : f32
%res = div %top, %btm : f32

// CHECK:      %0 = constant 12102203.161561485 : f32
// CHECK-NEXT: %x = var 'x' : f32
// CHECK-NEXT: %1 = mul %0, %x : f32
// CHECK-NEXT: %2 = add %sigma, %1 : i32
// CHECK-NEXT: %3 = bitcast i2f %2 to f32
// CHECK-NEXT: %sigma1 = tunable 'sigma' = 2129950675 : i32
// CHECK-NEXT: %4 = bitcast f2i %3 to i32
// CHECK-NEXT: %5 = sub %sigma1, %4 : i32
// CHECK-NEXT: %6 = bitcast i2f %5 to f32
// CHECK-NEXT: %top = sub %3, %6 : f32
// CHECK-NEXT: %sigma2 = tunable 'sigma' = 2129950675 : i32
// CHECK-NEXT: %btm = add %3, %6 : f32
// CHECK-NEXT: %7 = bitcast f2i %btm to i32
// CHECK-NEXT: %8 = sub %sigma2, %7 : i32
// CHECK-NEXT: %9 = bitcast i2f %8 to f32
// CHECK-NEXT: %10 = mul %top, %9 : f32

// LLVM:      define float @my_func(float %x, i32 %sigma, i32 %sigma_1, i32 %sigma_2) {
// LLVM-NEXT:   %1 = fmul float 0x4167154760000000, %x
// LLVM-NEXT:   %cast = fptosi float %1 to i32
// LLVM-NEXT:   %2 = add i32 %sigma, %cast
// LLVM-NEXT:   %3 = bitcast i32 %2 to float
// LLVM-NEXT:   %4 = bitcast float %3 to i32
// LLVM-NEXT:   %5 = sub i32 %sigma_1, %4
// LLVM-NEXT:   %6 = bitcast i32 %5 to float
// LLVM-NEXT:   %top = fsub float %3, %6
// LLVM-NEXT:   %btm = fadd float %3, %6
// LLVM-NEXT:   %7 = bitcast float %btm to i32
// LLVM-NEXT:   %8 = sub i32 %sigma_2, %7
// LLVM-NEXT:   %9 = bitcast i32 %8 to float
// LLVM-NEXT:   %10 = fmul float %top, %9
// LLVM-NEXT:   ret float %10
// LLVM-NEXT: }
