// RUN: ffcc-opt -p approx{exp,div},cse,simp,types %s | filecheck %s
// RUN: ffcc-opt -p approx{exp,div},cse,simp,types %s -f llvm | opt -S | filecheck %s --check-prefix=LLVM

%x = var x : f32
%one = constant 1 : f32
%e = constant e : f32
%mx = negate %x : f32
%exp = pow %e, %mx : f32
%one_p_ex = add %one, %exp : f32
%res = div %one, %one_p_ex : f32

// CHECK:      %L = tunable 'L' = 2129950675 : i32
// CHECK-NEXT: %one = constant 1 : f32
// CHECK-NEXT: %LB = tunable 'LB' = 1064975338 : i32
// CHECK-NEXT: %L1 = tunable 'L' = -12102203.161561485 : f32
// CHECK-NEXT: %x = var 'x' : f32
// CHECK-NEXT: %0 = mul %L1, %x : f32
// CHECK-NEXT: %1 = add %LB, %0 : i32
// CHECK-NEXT: %2 = bitcast i2f %1 to f32
// CHECK-NEXT: %one_p_ex = add %one, %2 : f32
// CHECK-NEXT: %3 = bitcast f2i %one_p_ex to i32
// CHECK-NEXT: %4 = sub %L, %3 : i32
// CHECK-NEXT: %5 = bitcast i2f %4 to f32

// LLVM:      define float @my_func(float %x, float %L, i32 %L_1, i32 %LB) {
// LLVM-NEXT:   %1 = fmul float %L, %x
// LLVM-NEXT:   %cast = fptosi float %1 to i32
// LLVM-NEXT:   %2 = add i32 %LB, %cast
// LLVM-NEXT:   %3 = bitcast i32 %2 to float
// LLVM-NEXT:   %one_p_ex = fadd float 1.000000e+00, %3
// LLVM-NEXT:   %4 = bitcast float %one_p_ex to i32
// LLVM-NEXT:   %5 = sub i32 %L_1, %4
// LLVM-NEXT:   %6 = bitcast i32 %5 to float
// LLVM-NEXT:   ret float %6
// LLVM-NEXT: }
