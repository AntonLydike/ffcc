// RUN: python -m ffcc -p approx,cse,simp,types %s | filecheck %s
// RUN: python -m ffcc -p approx,cse,simp,types %s -f llvm | opt -S | filecheck %s --check-prefix=LLVM

%x = var x : f32
%one = constant 1 : f32
%e = constant 2.718281828459045 : f32
%mx = negate %x : f32
%exp = pow %e, %mx : f32
%one_p_ex = add %one, %exp : f32
%res = div %one, %one_p_ex : f32

// CHECK:      %sigma = tunable 'sigma' = 2123145612 : i32
// CHECK-NEXT: %one = constant 1 : f32
// CHECK-NEXT: %sigma1 = tunable 'sigma' = 1061572806 : i32
// CHECK-NEXT: %0 = constant 12102203.161561485 : f32
// CHECK-NEXT: %x = var 'x' : f32
// CHECK-NEXT: %mx = negate %x : f32
// CHECK-NEXT: %1 = mul %0, %mx : f32
// CHECK-NEXT: %2 = add %sigma1, %1 : i32
// CHECK-NEXT: %3 = bitcast i2f %2 to f32
// CHECK-NEXT: %one_p_ex = add %one, %3 : f32
// CHECK-NEXT: %4 = bitcast f2i %one_p_ex to i32
// CHECK-NEXT: %5 = sub %sigma, %4 : i32
// CHECK-NEXT: %6 = bitcast i2f %5 to f32

// LLVM:        define float @my_func(float %x, i32 %sigma, i32 %sigma_1) {
// LLVM-NEXT:   %mx = fneg float %x
// LLVM-NEXT:   %1 = fmul float 0x4167154760000000, %mx
// LLVM-NEXT:   %cast = fptosi float %1 to i32
// LLVM-NEXT:   %2 = add i32 %sigma_1, %cast
// LLVM-NEXT:   %3 = bitcast i32 %2 to float
// LLVM-NEXT:   %one_p_ex = fadd float 1.000000e+00, %3
// LLVM-NEXT:   %4 = bitcast float %one_p_ex to i32
// LLVM-NEXT:   %5 = sub i32 %sigma, %4
// LLVM-NEXT:   %6 = bitcast i32 %5 to float
// LLVM-NEXT:   ret float %6
// LLVM-NEXT: }
