// RUN: ffcc -e "silu(x) = x / (1 + exp(-x))" -o torch | filecheck %s
// RUN: ffcc -e "silu(x) = x / (1 + exp(-x))" -o torch --approx=exp | filecheck %s --check-prefix EXP
// RUN: ffcc -e "silu(x) = x / (1 + exp(-x))" -o torch --approx=exp --tune=[-6,6] | filecheck %s --check-prefix TUNE


// CHECK-NEXT: import torch
// CHECK-NEXT: from torch import nn, Tensor
// CHECK-EMPTY:
// CHECK-EMPTY:
// CHECK-NEXT: class FastSilu(nn.Module):
// CHECK-NEXT:  def forward(self, x: Tensor) -> Tensor:
// CHECK-NEXT:          v0 = (1.0 + torch.pow(2.718281828459045, -x))
// CHECK-NEXT:          return (x / v0)


// EXP-NEXT: import torch
// EXP-NEXT: from torch import nn, Tensor
// EXP-EMPTY:
// EXP-EMPTY:
// EXP-NEXT: class FastSilu(nn.Module):
// EXP-NEXT:  def forward(self, x: Tensor) -> Tensor:
// EXP-NEXT:          v0 = (-12102203.161561485 * x)
// EXP-NEXT:          v1 = (1064988311.552 + v0)
// EXP-NEXT:          v2 = v1.type(torch.int32).view(torch.float32)
// EXP-NEXT:          return (x / (1.0 + v2))


// TUNE-NEXT: import torch
// TUNE-NEXT: from torch import nn, Tensor
// TUNE-EMPTY:
// TUNE-EMPTY:
// TUNE-NEXT: class FastSilu(nn.Module):
// TUNE-NEXT:     def forward(self, x: Tensor) -> Tensor:
// TUNE-NEXT:         v0 = (1064873152.0 + (-12104086.0 * x))
// TUNE-NEXT:         v1 = v0.type(torch.int32).view(torch.float32)
// TUNE-NEXT:         return (x / (1.0 + v1))
