%x = var x : f32
%one = constant 1 : f32
%e = constant e : f32
%mx = negate %x : f32
%exp = pow %e, %mx : f32
%one_p_ex = add %one, %exp : f32
%res = div %one, %one_p_ex : f32
%r = mul %x, %res : f32

// -----

// untuned
%sigma = tunable 's2' = 2129950675 : i32
%one = constant 1 : f32
%sigma1 = tunable 's1' = 1064975338 : i32
%0 = tunable 'L' = 12102203.161561485 : f32
%x = var 'x' : f32
%mx = negate %x : f32
%1 = mul %0, %mx : f32
%2 = add %sigma1, %1 : i32
%3 = bitcast i2f %2 to f32
%one_p_ex = add %one, %3 : f32
%4 = bitcast f2i %one_p_ex to i32
%5 = sub %sigma, %4 : i32
%6 = bitcast i2f %5 to f32
%r = mul %x, %6 : f32


// -----

// tune
%x = var 'x' : f32
%sigma = tunable 's2' = 2129881071 : i32
%one = tunable 'one' = 1.0119495391845703 : f32
%sigma1 = tunable 's1' = 1065039594 : i32
%0 = tunable 'L' = 12000943.0 : f32
%mx = negate %x : f32
%1 = mul %0, %mx : f32
%2 = add %sigma1, %1 : i32
%3 = bitcast i2f %2 to f32
%one_p_ex = add %one, %3 : f32
%4 = bitcast f2i %one_p_ex to i32
%5 = sub %sigma, %4 : i32
%6 = bitcast i2f %5 to f32
%r = mul %x, %6 : f32


// -----
// with newton on the division:
// yn = 2*y-x*y*y

%x = var 'x' : f32
%sigma = tunable 's2' = 2129947503 : i32
%one = tunable 'one' = 1.0133533477783203 : f32
%sigma1 = tunable 's1' = 1065043562 : i32
%0 = tunable 'L' = 12015791.0 : f32
%mx = negate %x : f32
%1 = mul %0, %mx : f32
%2 = add %sigma1, %1 : i32
%3 = bitcast i2f %2 to f32
%one_p_ex = add %one, %3 : f32
%4 = bitcast f2i %one_p_ex to i32
%5 = sub %sigma, %4 : i32
%y = bitcast i2f %5 to f32

// (2 * %y) - (%y * %y * %one_p_ex)
%c2 = tunable 'two' = 2.0 : f32
%_2 = mul %c2, %y : f32
%_0 = mul %one_p_ex, %y : f32
%_1 = mul %_0, %y : f32
%yn = sub %_2, %_1 : f32

%r = mul %x, %yn : f32


// -----
// with epsilon = 1

%x = var 'x' : f32
%c2 = tunable 'two' = 2.0035400390625 : f32
%sigma = tunable 's2' = 2129866479 : i32
%one = tunable 'one' = 1.0043811798095703 : f32
%sigma1 = tunable 's1' = 1065055082 : i32
%0 = tunable 'L' = 12083375.0 : f32
%mx = negate %x : f32
%1 = mul %0, %mx : f32
%2 = add %sigma1, %1 : i32
%3 = bitcast i2f %2 to f32
%one_p_ex = add %one, %3 : f32
%4 = bitcast f2i %one_p_ex to i32
%5 = sub %sigma, %4 : i32
%y = bitcast i2f %5 to f32
%_2 = mul %c2, %y : f32
%_0 = mul %one_p_ex, %y : f32
%_1 = mul %_0, %y : f32
%yn = sub %_2, %_1 : f32
%r = mul %x, %yn : f32
